[Unit]
Description=NutWatch Web Interface
After=network.target nut-server.service
Wants=nut-server.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/nutwatch
ExecStart=/opt/nutwatch/venv/bin/python /opt/nutwatch/app.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
